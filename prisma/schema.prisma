// =============================================================================
// Computed Ratings Tables (populated by data-pipeline compute_ratings.py)
// =============================================================================
// These tables are DROP/CREATE'd each time compute_ratings.py runs.
// They store the final processed ratings used by the Next.js application.

/// Per-season ratings for all component types (drivers, chassis, engines,
/// team principals, chief engineers, car designers).
/// Source: services/data-pipeline/compute_ratings.py
model component_ratings {
  id               Int     @id @default(autoincrement())
  year             Int
  role             String  // driver | chassis | engine | team_principal | chief_engineer | car_designer
  component_name   String
  team             String?
  raw_score        Float
  normalized_score Float
  rating           Float
  source           String  // table name this rating was derived from

  @@index([year, role], map: "idx_component_ratings_year_role")
  @@index([component_name], map: "idx_component_ratings_component_name")
}

/// Career-aggregated ratings using peak-weighted recency decay.
/// Source: services/data-pipeline/compute_ratings.py
model career_ratings {
  id                  Int    @id @default(autoincrement())
  role                String // driver | chassis | engine | team_principal | chief_engineer | car_designer
  component_name      String
  career_overall      Float
  seasons_count       Int
  peak_season_overall Float
  latest_year         Int

  @@index([role], map: "idx_career_ratings_role")
  @@index([component_name], map: "idx_career_ratings_name")
}

/// Decade-aggregated ratings for components.
/// Source: services/data-pipeline/compute_ratings.py
model decade_ratings {
  id                  Int    @id @default(autoincrement())
  role                String // driver | chassis | engine | team_principal | chief_engineer | car_designer
  component_name      String
  decade              String // e.g. "1980s", "1990s", "2000s", "2010s", "2020s"
  rating              Float
  seasons_count       Int
  peak_season_overall Float
  latest_year         Int

  @@index([role, decade], map: "idx_decade_ratings_role_decade")
  @@index([component_name], map: "idx_decade_ratings_name")
}
