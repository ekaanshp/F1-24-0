// =============================================================================
// Prisma Schema — F1 TeamBuilder
// =============================================================================
// Data source: Neon PostgreSQL (serverless, pooled connections)
// Generator: Prisma Client with Neon adapter
//
// Connection URLs are configured in prisma.config.ts (Prisma 7+)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// NextAuth.js Models
// =============================================================================
// These models are required by NextAuth for session management.
// See: https://authjs.dev/getting-started/adapters/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// Game Models
// =============================================================================

model DraftSession {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("in_progress") // in_progress | completed | abandoned
  spinsUsed Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Roster {
  id             String   @id @default(cuid())
  userId         String
  draftSessionId String
  createdAt      DateTime @default(now())
}

model HistoricalData {
  id   String @id @default(cuid())
  era  String
  team String
}

model LeaderboardEntry {
  id                String   @id @default(cuid())
  userId            String
  rosterId          String
  totalPoints       Int      @default(0)
  wins              Int      @default(0)
  perfectSeason     Boolean  @default(false)
  seasonCompletedAt DateTime @default(now())
}

// =============================================================================
// F1 Raw Data Tables (populated by data-pipeline scripts)
// =============================================================================
// These tables are populated via SQLAlchemy/Pandas in the services/data-pipeline
// directory. They store raw historical F1 data fetched from the RacingHub API.

/// Per-season driver statistics fetched from the RacingHub API.
/// Source: services/data-pipeline/fetch_data.py
///
/// Computed columns (nullable) are populated via SQL or scripts before
/// running compute_ratings.py. See formula.txt Section 2 for details.
model driver_seasons {
  id             Int     @id @default(autoincrement())
  driver_id      String?
  driver_name    String?
  year           BigInt?
  position       BigInt?
  points         Float?
  race_wins      BigInt?
  pole_positions BigInt?
  constructors   String?

  // --- Era metadata (formula.txt Section 7A/7B) ---
  race_count          Int?   // R(Y): number of races in this season
  max_win_points      Int?   // Max points awarded for a race win in this era
  max_points_available Float? // max_win_points × race_count
  n_drivers           Int?   // N(Y): count of distinct drivers in this season's championship

  // --- Sub-attribute 1: DOMINANCE (weight 0.30) ---
  win_rate       Float? // race_wins / race_count
  points_rate    Float? // points / max_points_available
  dominance_rate Float? // sqrt(win_rate × points_rate) — geometric mean

  // --- Sub-attribute 2: RACE_CRAFT (weight 0.25) ---
  normalized_position Float? // 1 - ((position - 1) / (n_drivers - 1))
  pawe                Float? // 0.6 × win_rate + 0.4 × normalized_position

  // --- Sub-attribute 3: QUALIFYING_PROWESS (weight 0.20) ---
  pole_rate Float? // pole_positions / race_count

  // --- Sub-attribute 4: CONSISTENCY (weight 0.15) ---
  points_harvest_rate Float? // points / max_points_available
  consistency_raw     Float? // points_harvest_rate / max(points_harvest_rate in year)

  // --- Sub-attribute 5: CHAMPIONSHIP_PEDIGREE (weight 0.10) ---
  champ_percentile Float? // 1 - ((position - 1) / (n_drivers - 1)), scaled 0-1

  @@index([driver_id], map: "idx_driver_seasons_driver_id")
  @@index([year], map: "idx_driver_seasons_year")
}

/// Per-season constructor standings fetched from the RacingHub API.
/// Source: services/data-pipeline/fetch_data.py
///
/// Computed columns (nullable) — see formula.txt Section 3.
model constructor_seasons {
  id               Int     @id @default(autoincrement())
  constructor_id   String?
  constructor_name String?
  year             BigInt?
  position         BigInt?
  points           Float?
  race_wins        BigInt?
  pole_positions   BigInt?

  // --- Era metadata ---
  race_count            Int?   // R(Y)
  max_win_points        Int?   // Max points for a win in this era
  second_place_points   Int?   // Points for 2nd place in this era
  max_constructor_points Float? // (max_win_points + second_place_points) × race_count
  n_constructors        Int?   // T(Y): count of distinct constructors in this season

  // --- Sub-attribute 1: PERFORMANCE (weight 0.30) ---
  win_rate Float? // race_wins / race_count

  // --- Sub-attribute 2: COMPETITIVENESS (weight 0.30) ---
  competitiveness_rate Float? // points / max_constructor_points

  // --- Sub-attribute 3: ENGINEERING_EXCELLENCE (weight 0.25) ---
  pole_rate Float? // pole_positions / race_count

  // --- Sub-attribute 4: CHAMPIONSHIP_STANDING (weight 0.15) ---
  champ_percentile Float? // 1 - ((position - 1) / (n_constructors - 1))

  @@index([constructor_id], map: "idx_constructor_seasons_constructor_id")
  @@index([year], map: "idx_constructor_seasons_year")
}

/// Per-season constructor data joined with engine manufacturer info.
/// Source: services/data-pipeline/fetch_constructor_data_with_engine.py
///
/// Computed columns (nullable) — see formula.txt Section 4.
/// These per-team-row values feed into engine manufacturer aggregation.
model constructor_seasons_with_engines {
  id                       Int     @id @default(autoincrement())
  year                     BigInt?
  team_name                String?
  engine_manufacturer_name String?
  position                 BigInt?
  points                   Float?
  race_wins                BigInt?
  pole_positions           BigInt?

  // --- Era metadata ---
  race_count            Int?   // R(Y)
  max_win_points        Int?   // Max points for a win in this era
  second_place_points   Int?   // Points for 2nd place in this era
  max_constructor_points Float? // (max_win_points + second_place_points) × race_count
  n_constructors        Int?   // T(Y): count of distinct constructors in this season

  // --- Per-team rate metrics (used in engine aggregation) ---
  pole_rate              Float? // pole_positions / race_count
  points_harvest_rate    Float? // points / max_constructor_points

  @@index([engine_manufacturer_name], map: "idx_cswe_engine")
  @@index([year], map: "idx_cswe_year")
}

// =============================================================================
// F1 Personnel Tables (populated by data-pipeline upload_personnel.py)
// =============================================================================

/// Car designers mapped to teams per season.
/// Source: services/data-pipeline/upload_personnel.py + car_designers.csv
///
/// Computed columns (nullable) — see formula.txt Section 5.
/// 'team' must EXACTLY match constructor_name in constructor_seasons
/// for the merge to work. Use constructor_match to verify alignment.
model car_designers {
  id   Int    @id @default(autoincrement())
  year Int
  name String
  team String

  // --- Name alignment ---
  constructor_match String? // Resolved constructor_name from constructor_seasons (for validation)

  // --- Inputs from constructor ratings (joined on year+team) ---
  constructor_season_overall Float? // The constructor's computed season overall → RESULTS_DELIVERY
  competitiveness_score      Float? // Constructor's competitiveness score → OPERATIONAL_EXCELLENCE
  champ_percentile           Float? // 1 - ((position-1)/(n_constructors-1)) from constructor data

  // --- Sub-attribute 2: DEVELOPMENT_TRAJECTORY (weight 0.25) ---
  prev_champ_percentile Float? // champ_percentile from the previous season under this leader
  development_delta     Float? // champ_percentile - prev_champ_percentile

  // --- Sub-attribute 3: RESOURCE_EFFICIENCY (weight 0.20) ---
  historical_avg_percentile Float? // Mean champ_percentile for this team across ALL seasons
  overperformance           Float? // champ_percentile - historical_avg_percentile

  // --- Sub-attribute 5: LONGEVITY_STABILITY (weight 0.10) ---
  streak Int? // Consecutive seasons with champ_percentile >= 0.5 under this leader
}

/// Team principals mapped to teams per season.
