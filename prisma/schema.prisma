  champ_percentile           Float? // 1 - ((position-1)/(n_constructors-1)) from constructor data

  // --- Sub-attribute 2: DEVELOPMENT_TRAJECTORY (weight 0.25) ---
  prev_champ_percentile Float? // champ_percentile from the previous season under this leader
  development_delta     Float? // champ_percentile - prev_champ_percentile

