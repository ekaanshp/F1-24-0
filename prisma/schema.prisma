// =============================================================================
// Prisma Schema — F1 TeamBuilder
// =============================================================================
// Data source: Neon PostgreSQL (serverless, pooled connections)
// Generator: Prisma Client with Neon adapter
//
// Connection URLs are configured in prisma.config.ts (Prisma 7+)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// NextAuth.js Models
// =============================================================================
// These models are required by NextAuth for session management.
// See: https://authjs.dev/getting-started/adapters/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// Game Models
// =============================================================================

model DraftSession {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("in_progress") // in_progress | completed | abandoned
  spinsUsed Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Roster {
  id             String   @id @default(cuid())
  userId         String
  draftSessionId String
  createdAt      DateTime @default(now())
}

model HistoricalData {
  id   String @id @default(cuid())
  era  String
  team String
}

model LeaderboardEntry {
  id                String   @id @default(cuid())
  userId            String
  rosterId          String
  totalPoints       Int      @default(0)
  wins              Int      @default(0)
  perfectSeason     Boolean  @default(false)
  seasonCompletedAt DateTime @default(now())
}

// =============================================================================
// F1 Raw Data Tables (populated by data-pipeline scripts)
// =============================================================================
// These tables are populated via SQLAlchemy/Pandas in the services/data-pipeline
// directory. They store raw historical F1 data fetched from the RacingHub API.

/// Per-season driver statistics fetched from the RacingHub API.
/// Source: services/data-pipeline/fetch_data.py
model driver_seasons {
  id             Int     @id @default(autoincrement())
  driver_id      String?
  driver_name    String?
  year           BigInt?
  position       BigInt?
  points         Float?
  race_wins      BigInt?
  pole_positions BigInt?
  constructors   String?

  @@index([driver_id], map: "idx_driver_seasons_driver_id")
  @@index([year], map: "idx_driver_seasons_year")
}

/// Per-season constructor standings fetched from the RacingHub API.
/// Source: services/data-pipeline/fetch_data.py
model constructor_seasons {
  id               Int     @id @default(autoincrement())
  constructor_id   String?
  constructor_name String?
  year             BigInt?
  position         BigInt?
  points           Float?
  race_wins        BigInt?
  pole_positions   BigInt?

  @@index([constructor_id], map: "idx_constructor_seasons_constructor_id")
  @@index([year], map: "idx_constructor_seasons_year")
}

/// Per-season constructor data joined with engine manufacturer info.
/// Source: services/data-pipeline/fetch_constructor_data_with_engine.py
model constructor_seasons_with_engines {
  id                       Int     @id @default(autoincrement())
  year                     BigInt?
  team_name                String?
  engine_manufacturer_name String?
  position                 BigInt?
  points                   Float?
  race_wins                BigInt?
  pole_positions           BigInt?

  @@index([engine_manufacturer_name], map: "idx_cswe_engine")
  @@index([year], map: "idx_cswe_year")
}

// =============================================================================
// F1 Personnel Tables (populated by data-pipeline upload_personnel.py)
// =============================================================================

/// Car designers mapped to teams per season.
/// Source: services/data-pipeline/upload_personnel.py + car_designers.csv
model car_designers {
  id   Int    @id @default(autoincrement())
  year Int
  name String
  team String
}

/// Team principals mapped to teams per season.
/// Source: services/data-pipeline/upload_personnel.py + team_principals.csv
model team_principals {
  id   Int    @id @default(autoincrement())
  year Int
  name String
  team String
}

/// Chief/race engineers mapped to teams and drivers per season.
/// Source: services/data-pipeline/upload_personnel.py + team_engineers.csv
model team_engineers {
  id     Int     @id @default(autoincrement())
  year   Int
  name   String
  team   String
  driver String?
}

// =============================================================================
// Computed Ratings Tables (populated by data-pipeline compute_ratings.py)
// =============================================================================
// These tables are DROP/CREATE'd each time compute_ratings.py runs.
// They store the final processed ratings used by the Next.js application.

/// Per-season ratings for all component types (drivers, chassis, engines,
/// team principals, chief engineers, car designers).
/// Source: services/data-pipeline/compute_ratings.py
model component_ratings {
  id               Int     @id @default(autoincrement())
  year             Int
  role             String  // driver | chassis | engine | team_principal | chief_engineer | car_designer
  component_name   String
  team             String?
  raw_score        Float
  normalized_score Float
  rating           Float
  source           String  // table name this rating was derived from

  @@index([year, role], map: "idx_component_ratings_year_role")
  @@index([component_name], map: "idx_component_ratings_component_name")
}

/// Career-aggregated ratings using peak-weighted recency decay.
/// Source: services/data-pipeline/compute_ratings.py
model career_ratings {
  id                  Int    @id @default(autoincrement())
  role                String // driver | chassis | engine | team_principal | chief_engineer | car_designer
  component_name      String
  career_overall      Float
  seasons_count       Int
  peak_season_overall Float
  latest_year         Int

  @@index([role], map: "idx_career_ratings_role")
  @@index([component_name], map: "idx_career_ratings_name")
}
